# Telegram
BOT_TOKEN=
ADMIN_IDS=123456789

# App
APP_ENV=development
PUBLIC_BASE_URL=https://bot.example.com
WEBHOOK_SECRET_PATH=change-me
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://store:change_me@db:5432/store
REDIS_URL=redis://redis:6379/0
STORE_NAME=متجري الرقمي
SUPPORT_USERNAME=@your_support

# Generate with: python -m app.cli generate-key
DATA_ENCRYPTION_KEY=

# Supplier API. Keep disabled until the supplier contract is verified.
SUPPLIER_ENABLED=false
SUPPLIER_BASE_URL=https://supplier.example.com
SUPPLIER_API_KEY=
SUPPLIER_ME_PATH=/api/reseller/me
SUPPLIER_PRODUCTS_PATH=/api/reseller/products
SUPPLIER_QUOTE_PATH=/api/reseller/quote
SUPPLIER_CREATE_ORDER_PATH=/api/reseller/orders
SUPPLIER_ORDER_STATUS_PATH=/api/reseller/orders/{order_id}
SUPPLIER_ACTIVATION_IDENTIFIER_PATH=/api/reseller/orders/{order_id}/activation-identifier
SUPPLIER_CATALOG_SYNC_MINUTES=60

# Binance Pay Merchant (not a personal Binance API key)
BINANCE_PAY_ENABLED=false
BINANCE_PAY_API_KEY=
BINANCE_PAY_SECRET_KEY=
BINANCE_PAY_BASE_URL=https://bpay.binanceapi.com
BINANCE_WEBHOOK_TOLERANCE_SECONDS=300

# Jeeb personal-wallet confirmation through a trusted Android notification relay.
# Keep disabled until the relay is configured on the wallet owner's phone.
JEEB_AUTO_CONFIRM_ENABLED=false
JEEB_RELAY_SECRET=
JEEB_RELAY_DEVICE_ID=
JEEB_RELAY_TOLERANCE_SECONDS=300
# Google Play alternative to the custom APK. Generate a 48+ character random
# token, configure the supplied MacroDroid template, then test while
# JEEB_AUTO_CONFIRM_ENABLED=false before enabling automatic credit.
JEEB_MACRODROID_RELAY_ENABLED=false
JEEB_MACRODROID_RELAY_TOKEN=
JEEB_EVENT_MAX_AGE_HOURS=24
JEEB_INTENT_TTL_MINUTES=30

# Runtime
LOG_LEVEL=INFO
ORDER_WORKER_INTERVAL_SECONDS=5
ORDER_MAX_RETRIES=3
