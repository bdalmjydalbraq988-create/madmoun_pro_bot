# Telegram
BOT_TOKEN=
ADMIN_IDS=8884716304

# App
APP_ENV=development
PUBLIC_BASE_URL=https://bot.example.com
WEBHOOK_SECRET_PATH=change-me
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://store:change_me@db:5432/store
REDIS_URL=redis://redis:6379/0
STORE_NAME=مضمون برو
SUPPORT_USERNAME=@your_support

# Generate with: python -m app.cli generate-key
DATA_ENCRYPTION_KEY=

# Supplier API. Keep disabled until the supplier contract is verified.
SUPPLIER_ENABLED=false
SUPPLIER_BASE_URL=https://ventetelegrambotrailway-production.up.railway.app
SUPPLIER_API_KEY=
SUPPLIER_ME_PATH=/api/reseller/me
SUPPLIER_PRODUCTS_PATH=/api/reseller/products
SUPPLIER_QUOTE_PATH=/api/reseller/quote
SUPPLIER_CREATE_ORDER_PATH=/api/reseller/orders
SUPPLIER_ORDER_STATUS_PATH=/api/reseller/orders/{order_id}
SUPPLIER_ACTIVATION_IDENTIFIER_PATH=/api/reseller/orders/{order_id}/activation-identifier

# Binance Pay Merchant (not a personal Binance API key)
BINANCE_PAY_ENABLED=false
BINANCE_PAY_API_KEY=
BINANCE_PAY_SECRET_KEY=
BINANCE_PAY_BASE_URL=https://bpay.binanceapi.com
BINANCE_WEBHOOK_TOLERANCE_SECONDS=300

# Runtime
LOG_LEVEL=INFO
ORDER_WORKER_INTERVAL_SECONDS=5
ORDER_MAX_RETRIES=3
